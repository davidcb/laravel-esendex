{
  "name": "davidcb/laravel-esendex",
  "description": "Laravel wrapper for Esendex",
  "keywords": [
    "laravel",
    "esendex",
    "integration",
    "sms"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "David Couto",
      "email": "davidcouto@gmail.com"
    }
  ],
  "require": {
    "php": "^7.3|^8.0",
    "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
    "esendex/sdk": "^2.*.*|^3.*.*"
  },
  "autoload": {
    "psr-4": {
      "Davidcb\\LaravelEsendex\\": "src/Davidcb/LaravelEsendex/"
    }
  },
  "minimum-stability": "dev",
  "extra": {
    "laravel": {
      "providers": [
        "Davidcb\\LaravelEsendex\\LaravelEsendexServiceProvider"
      ],
      "aliases": {
        "LaravelEsendex": "Davidcb\\LaravelEsendex\\Facades\\LaravelEsendex"
      }
    }
  }
}
